                        // line icon
                        a.btn.btn-dark.btn-social.mx-2(href='https://line.me/R/ti/p/%40revivepilates', aria-label='Line', target='_blank')
                            i.fab.fa-line
                        // facebook icon
                        a.btn.btn-dark.btn-social.mx-2(href='https://web.facebook.com/people/Revive-Pilates-Studio-Wellness/61584033732719/?_rdc=1&_rdr#', aria-label='Facebook', target='_blank')
                            i.fab.fa-facebook-f
                        // instagram icon
                        a.btn.btn-dark.btn-social.mx-2(href='https://www.instagram.com/revivepilatesbkk', aria-label='Instagram', target='_blank')
                            i.fab.fa-instagram
                    .col-lg-4.text-lg-end
